/*
  # Verhindert MIME-Type-Sniffing
  X-Content-Type-Options: nosniff

  # Clickjacking-Schutz
  X-Frame-Options: SAMEORIGIN

  # XSS-Schutz (Legacy-Browser)
  X-XSS-Protection: 1; mode=block

  # Referrer-Informationen einschränken
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy – nicht benötigte Browser-APIs sperren
  Permissions-Policy: camera=(), microphone=(), geolocation=()

  # HSTS – erzwingt HTTPS für 1 Jahr
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy
  # WICHTIG: Vor dem Aktivieren testen – ggf. Quellen für eigene Scripts/Fonts ergänzen
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.anthropic.com https://*.supabase.co; frame-ancestors 'none';
